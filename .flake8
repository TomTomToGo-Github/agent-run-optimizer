[flake8]

# Enforce a high line length threshold instead of disabling it entirely.
# Black formats line lengths > 88 characters, leading to conflicts with flake8;
# however excessively long comments and string literals are still undesirable.
max-line-length = 120

# The following errors are excluded because they conflict with Black:
# E203: Whitespace before ':'
# W503: Line break occurred before a binary operator
# D202: No blank lines allowed after function docstring

# The numpy docstring convention is followed by setting docstring-convention to all and
# excluding the following errors:
# D107: Missing docstring in __init__
# D203: 1 blank line required before class docstring
# D213: Multi-line docstring summary should start at the second line
# D402: First line should not be the function's signature
# D413: Missing blank line after last section
# D415: First line should end with a period, question mark, or exclamation point
# D416: Section name should end with a colon
# D417: Missing argument descriptions in the docstring

# The following errors are excluded for other reasons:
# D204: 1 blank line required after class docstring
# D401: First line should be in imperative mood; ignored -- too many false negatives
# E131: continuation line unaligned for hanging indent; Black formats this anyway

docstring-convention = all
extend-ignore = E131, E203, W503, D202, D107, D203, D204, D213, D401, D402, D413, D415, D416, D417

per-file-ignores =
    test*.py:D101,D102,D103
    conftest.py:D101,D102,D103

import-order-style = smarkets
application-import-names = ai_reproducibility